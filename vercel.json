{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "projectSettings": {
    "framework": null,
    "nodeVersion": "20.x"
  },
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    { "src": "/build/(.*)", "dest": "/public/build/$1" },
    { "src": "/(css|js|images|fonts)/(.*)", "dest": "/public/$1/$2" },
    {
      "src": "/(.*\\.(css|js|gif|jpg|jpeg|png|svg|ico|txt|xml|woff|woff2|ttf|eot))$",
      "dest": "/public/$1"
    },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}