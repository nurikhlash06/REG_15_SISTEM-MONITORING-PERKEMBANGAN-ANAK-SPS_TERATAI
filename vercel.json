{
  "version": 2,
  "buildCommand": "php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
  "outputDirectory": "public",
  "projectSettings": {
    "framework": null,
    "nodeVersion": "20.x"
  },
  "functions": {
    "index.php": {
      "runtime": "vercel-php@0.7.4",
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/build/(.*)", "dest": "/build/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/fonts/(.*)", "dest": "/fonts/$1" },
    { "src": "/(.*\\.(css|js|gif|jpg|jpeg|png|svg|ico|txt|xml|woff|woff2|ttf|eot))$", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}